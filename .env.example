# Copy to .env and fill in secrets:
#   cp .env.example .env

# Gemini (preferred): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Or the same key under Google’s generic name:
# GOOGLE_API_KEY=

IIE_LLM_PROVIDER=gemini
IIE_LLM_MODEL=gemini-2.5-flash-lite

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

IIE_OFFLINE=0
IIE_EMBED_MODEL=all-MiniLM-L6-v2

# CLI inject client (python -m app.main inject)
#IIE_API_URL=http://127.0.0.1:8000
#IIE_INJECT_CHANNEL=sim_channel
#IIE_INJECT_SPEAKER=worker_1

#IIE_STORAGE_DIR=

IIE_EMIT_MIN_MESSAGES=2

# false = incidents stay ACTIVE until a resolution follow-up or POST /resolve/{id}
IIE_AUTO_RESOLVE=false

# true = "cabinet open now" style messages attach to latest active incident on that channel
IIE_RESOLUTION_ROUTING=true

# Looser cosine merge for clustering (0.55–0.75 typical). Lexical/anchor links still apply.
#IIE_EMBED_CLUSTER_THRESHOLD=0.62

IIE_EOF_FLUSH=true
